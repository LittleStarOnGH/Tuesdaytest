    </div>

    <!-- Controller View (Mobile) -->
    <div id="controller-view" class="hidden w-full h-full p-4 flex flex-col justify-between overflow-y-auto bg-slate-950">
        <div class="space-y-3">
            <div class="text-center">
                <h2 class="text-base font-bold text-indigo-400">🎛️Guest Control</h2>
            </div>

            <div class="bg-slate-900/80 p-2 rounded-xl border border-slate-800">
                <div class="grid grid-cols-2 gap-2">
                    <button id="btn-touch-mode" onclick="switchControlMode('touch')" class="bg-indigo-600 py-2 rounded-lg text-xs font-bold shadow-md">🎯 Touch Pad </button>
                    <button id="btn-twin-mode" onclick="switchControlMode('twin')" class="bg-slate-800 py-2 rounded-lg text-xs font-bold">👁️ Camera Scan</button>
                    <button onclick="sendAction('shape', 'live_camera')" class="bg-blue-600 hover:bg-blue-500 py-2 rounded-md text-[10px] font-bold shadow-lg text-white">📷 Live Camera</button>
                </div>
            </div>

            <div class="relative w-full">
                <div id="area-touch-mode" class="w-full h-72 bg-slate-950 rounded-xl border-2 border-dashed border-slate-700 flex flex-col justify-center items-center text-center p-2 touch-none active:border-indigo-500 transition-all">
                    <span class="text-sm text-slate-300 font-bold">Virtual Touchpad</span>
                    <span class="text-[10px] text-slate-500 mt-1">Use this touchpad to control the object</span>
                </div>
                <div id="area-twin-mode" class="hidden w-full bg-slate-900 rounded-xl border border-slate-800 p-2 text-center space-y-2">
                    <div class="relative w-full h-72 bg-black rounded-lg overflow-hidden border border-slate-700">
                        <button id="btn-scan-object" onclick="captureAndSendObject()" class="mt-3 w-full bg-pink-600 hover:bg-pink-700 text-white py-2 rounded-lg text-[11px] font-bold shadow-lg transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                        📸 Scan this object to the hologram display
                        </button>
                        <video id="webcam-video" class="w-full h-full object-cover" autoplay playsinline muted></video>
                        <canvas id="tracker-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
                    </div>
                </div>
            </div>

            <div class="bg-slate-900/80 p-3 rounded-xl border border-slate-800 space-y-3">
                <div class="grid grid-cols-4 gap-2">
                    <button onclick="sendAction('shape', 'torus')" class="bg-slate-800 hover:bg-slate-700 py-2 rounded-md text-[10px] font-medium">วงแหวน</button>
                    <button onclick="sendAction('shape', 'crystal')" class="bg-slate-800 hover:bg-slate-700 py-2 rounded-md text-[10px] font-medium">คริสตัล</button>
                    <button onclick="sendAction('shape', 'cone')" class="bg-slate-800 hover:bg-slate-700 py-2 rounded-md text-[10px] font-medium">ทรงกรวย</button>
                    <button onclick="sendAction('shape', 'custom_artifact')" class="bg-emerald-600 hover:bg-emerald-500 py-2 rounded-md text-[10px] font-bold shadow-lg text-white">🚪 Door Lock</button>
                </div>
                <div class="pt-2 border-t border-slate-800">
                    <label class="block text-[11px] font-bold text-slate-300 mb-2">🎨 Colour</label>
                    <!-- ใช้ JSColor แทน Input แบบเดิม -->
                    <input id="custom-color-picker" data-jscolor="{ value:'#00ffcc', format:'hex', onFineChange:'sendColorUpdate(this)' }" class="w-full h-10 cursor-pointer rounded-md border-2 border-slate-600 bg-slate-800 p-1 text-center font-mono text-sm text-white focus:outline-none">
                </div>
            </div>

            <div class="bg-slate-900/80 p-3 rounded-xl border border-slate-800 space-y-3">
                <div class="flex justify-between text-[10px] font-bold text-slate-400">
                    <span>Scaling </span>
                    <span id="scale-val" class="text-indigo-400">100%</span>
                </div>
                <input type="range" min="30" max="250" value="100" oninput="document.getElementById('scale-val').innerText = this.value + '%'; sendAction('scale', this.value)" class="w-full accent-indigo-500">
                <div class="flex justify-between text-[10px] font-bold text-slate-400 pt-2">
                    <span>Offset</span>
                    <span id="offset-val" class="text-indigo-400">130px</span>
                </div>
                <input type="range" min="40" max="400" value="130" oninput="document.getElementById('offset-val').innerText = this.value + 'px'; sendAction('offset', this.value)" class="w-full accent-indigo-500">
            </div>
        </div>

        <div class="flex gap-2 pt-2 pb-4">
            <button onclick="sendAction('toggleUI', '')" class="flex-1 bg-red-900/50 border border-red-800 py-2 rounded-xl text-[10px] font-bold text-red-200">👁️ Hide the code</button>
            <button onclick="sendAction('toggleGuides', '')" class="flex-1 bg-slate-800 border border-slate-700 py-2 rounded-xl text-[10px] font-bold">🎯 Hide the grid lines</button>
        </div>
    </div>

    <script>
        // ฟังก์ชันช่วยส่งข้อมูลสีจาก JSColor
        function sendColorUpdate(picker) {
            sendAction('color', picker.toHEXString());
        }

        let scenes = [], cameras = [], renderer, currentMeshes = [];
        let peer, conn, myRole = '';
        let baseScale = 1.0, baseOffset = 130; 
        let currentMode = 'touch';
        let videoElement, canvasElement, canvasCtx, detector;
        let animationFrameId; 

        const viewAngles = [0, (2 * Math.PI) / 3, (4 * Math.PI) / 3];

        function generateSimpleId() { return "uea-twin-" + Math.floor(1000 + Math.random() * 9000).toString(); }
        
        function showControllerSetup() {
            document.getElementById('mode-selection').classList.add('hidden');
            document.getElementById('controller-setup').classList.remove('hidden');
        }
        function showControllerSetup() {
            document.getElementById('mode-selection').classList.add('hidden');
            document.getElementById('controller-setup').classList.remove('hidden');
        }

        //ฟังก์ชันพากลับไปยังหน้าแรกเมื่อกดลูกศรย้อนกลับ
        function goBackToModeSelection() {
            document.getElementById('controller-setup').classList.add('hidden');
            document.getElementById('mode-selection').classList.remove('hidden');
            // เคลียร์ค่าตัวเลขในช่อง input ทิ้งด้วยเพื่อความสะอาดเรียบร้อย
            document.getElementById('join-id-input').value = '';
        }

        function initPeer(role) {
            myRole = role;
            document.getElementById('mode-selection').classList.add('hidden');
            if (role === 'screen') {
                document.getElementById('screen-view').classList.remove('hidden');
                init3DMultiView();
                const roomCode = generateSimpleId();
                peer = new Peer(roomCode, { debug: 2 });
                peer.on('open', id => document.getElementById('display-peer-id').innerText = id.replace("uea-twin-", ""));
                peer.on('connection', connection => { conn = connection; setupReceiver(); });
                
                peer.on('call', call => {
                    call.answer(); 
                    call.on('stream', remoteStream => {
                        const remoteVid = document.getElementById('remote-video');
                        remoteVid.srcObject = remoteStream;
                        remoteVid.classList.remove('hidden');
                    });
                });
            }
        }
        // [แก้ไข] แทนที่ฟังก์ชันเดิมด้วยฟังก์ชันนี้ (สังเกตคำว่า async)
async function captureAndSendObject() {
    if (!videoElement || videoElement.readyState !== videoElement.HAVE_CURRENT_DATA) return;
    
    const btn = document.getElementById('btn-scan-object');
    const originalText = btn.innerText;
    
    // 1. เปลี่ยนสถานะปุ่มเพื่อป้องกันการกดซ้ำ
    btn.innerText = "⏳ AI กำลังลบพื้นหลัง (รอ 1-3 วินาที)...";
    btn.disabled = true;

    try {
        // 2. แคปภาพจากกล้องลง Canvas
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = videoElement.videoWidth;
        tempCanvas.height = videoElement.videoHeight;
        const ctx = tempCanvas.getContext('2d');
        ctx.drawImage(videoElement, 0, 0, tempCanvas.width, tempCanvas.height);
        
        // 3. แปลง Canvas เป็นไฟล์ Blob เพื่อเตรียมส่งให้ AI
        const imageBlob = await new Promise(resolve => tempCanvas.toBlob(resolve, 'image/jpeg', 0.9));
        
        // 4. สั่งให้ AI ลบพื้นหลัง (ได้ผลลัพธ์เป็นภาพโปร่งใส)
        const processedBlob = await imglyRemoveBackground(imageBlob);
        
        // 5. แปลงภาพที่ลบพื้นหลังแล้วกลับเป็น Base64 เพื่อส่งผ่านเน็ต
        const reader = new FileReader();
        reader.readAsDataURL(processedBlob);
        reader.onloadend = function() {
            const base64data = reader.result;
            // ส่งภาพทะลุพื้นหลังไปที่จอ
            sendAction('scanned_image', base64data);
            
            // คืนค่าปุ่มกลับมาเหมือนเดิม
            btn.innerText = originalText;
            btn.disabled = false;
        }
    } catch (error) {
        console.error("AI ตัดพื้นหลังผิดพลาด:", error);
        alert("เกิดข้อผิดพลาด หรืออุปกรณ์ RAM ไม่พอสำหรับการรัน AI บนเบราว์เซอร์");
        btn.innerText = originalText;
        btn.disabled = false;
    }
}
        function connectToScreen() {
            const targetInput = document.getElementById('join-id-input').value.trim();
            if (!targetInput) return alert('กรุณากรอกรหัสห้องก่อนครับ');
            const fullTargetId = "uea-twin-" + targetInput;
            peer = new Peer({ debug: 2 });
            peer.on('open', () => {
                conn = peer.connect(fullTargetId);
                conn.on('open', () => {
                    document.getElementById('controller-setup').classList.add('hidden');
                    document.getElementById('controller-view').classList.remove('hidden');
                    setupTouchpad();
                    initTrackingSystem(); 

                });
            });
        }

        function sendAction(type, value) { if (conn && conn.open) conn.send({ type: type, value: value }); }

        function setupReceiver() {
            conn.on('data', data => {
                if (data.type === 'shape') {
                    if (data.value == 'live_camera'){
                        createLiveVideoMesh();
                    } else {
                        const picker = document.getElementById('custom-color-picker');
                        // อ่านค่าสีจาก property ของ JSColor ถ้ามี
                        const currentColor = picker && picker.jscolor ? picker.jscolor.toHEXString() : "#00ffcc";
                        recreateAllGeometries(data.value, currentColor);
                    }
                } else if (data.type === 'color') {
                    currentMeshes.forEach(mesh => { 
                        if(mesh.userData && mesh.userData.isCustom) return; 
                        if(mesh.material && mesh.material.color) mesh.material.color.set(data.value); 
                    });
                } else if (data.type === 'scale') {
                    baseScale = data.value / 100;
                    currentMeshes.forEach(mesh => {
                        let s = (mesh.userData && mesh.userData.isCustom) ? baseScale * mesh.userData.initialScale : baseScale;
                        mesh.scale.set(s, s, s);
                    });
                } else if (data.type === 'offset') {
                    baseOffset = parseInt(data.value);
                } else if (data.type === 'rotate') {
                    currentMeshes.forEach(mesh => {
                        mesh.rotation.y += data.value.deltaX * 0.012;
                        mesh.rotation.x += data.value.deltaY * 0.012;
                    });
                } else if (data.type === 'twin_rotate') {
                    applyTwinRotation(data.value);
                } else if (data.type === 'toggleUI') {
                    document.getElementById('room-id-box').classList.toggle('opacity-0');
                } else if (data.type === 'toggleGuides') {
                    document.getElementById('guide-lines').classList.toggle('opacity-0');
                } else if (data.type === 'scanned_image') {
                    createScannedMesh(data.value);
                }
            });
        }

        function applyTwinRotation(value) {
            currentMeshes.forEach((mesh, idx) => {
                mesh.rotation.y = viewAngles[idx] + value.y;
                mesh.rotation.x = value.x;
                mesh.rotation.z = value.z;
            });
        }

        function switchControlMode(mode) {
            currentMode = mode;
            const btnTouch = document.getElementById('btn-touch-mode'), btnTwin = document.getElementById('btn-twin-mode');
            const areaTouch = document.getElementById('area-touch-mode'), areaTwin = document.getElementById('area-twin-mode');
            if (mode === 'touch') {
                btnTouch.className = "bg-indigo-600 py-2 rounded-lg text-xs font-bold shadow-md"; 
                btnTwin.className = "bg-slate-800 py-2 rounded-lg text-xs font-bold";
                areaTouch.classList.remove('hidden'); areaTwin.classList.add('hidden'); 
                stopCameraStream();
            } else {
                btnTwin.className = "bg-indigo-600 py-2 rounded-lg text-xs font-bold shadow-md"; 
                btnTouch.className = "bg-slate-800 py-2 rounded-lg text-xs font-bold";
                areaTwin.classList.remove('hidden'); areaTouch.classList.add('hidden'); 
                startCameraStream();
            }
        }

        function initTrackingSystem() {
            videoElement = document.getElementById('webcam-video');
            canvasElement = document.getElementById('tracker-canvas');
            canvasCtx = canvasElement.getContext('2d');
            detector = new AR.Detector();
        }

        function startCameraStream() {
            const constraints = { video: { facingMode: { ideal: "environment" } } };
            navigator.mediaDevices.getUserMedia(constraints)
                .then(stream => { handleStream(stream); })
                .catch(() => { 
                    navigator.mediaDevices.getUserMedia({ video: true }).then(stream => { handleStream(stream); }); 
                });
        }

        function handleStream(stream) {
            videoElement.srcObject = stream; 
            videoElement.play(); 
            animationFrameId = requestAnimationFrame(processWebcamFrame);
            
            if (peer && conn && conn.open && conn.peer) {
                peer.call(conn.peer, stream);
            }
        }

        function stopCameraStream() { 
            if (animationFrameId) cancelAnimationFrame(animationFrameId); 
            if (videoElement && videoElement.srcObject) videoElement.srcObject.getTracks().forEach(t => t.stop()); 
        }

        function processWebcamFrame() {
            if (videoElement.readyState === videoElement.HAVE_CURRENT_DATA && currentMode === 'twin') {
                canvasElement.width = videoElement.videoWidth; canvasElement.height = videoElement.videoHeight;
                canvasCtx.drawImage(videoElement, 0, 0, canvasElement.width, canvasElement.height);
                const markers = detector.detect(canvasCtx.getImageData(0, 0, canvasElement.width, canvasElement.height));
                if (markers.length > 0) {
                    const m = markers[0];
                    canvasCtx.strokeStyle = "#39ff14"; canvasCtx.lineWidth = 3; canvasCtx.beginPath();
                    m.corners.forEach((c, i) => i === 0 ? canvasCtx.moveTo(c.x, c.y) : canvasCtx.lineTo(c.x, c.y));
                    canvasCtx.closePath(); canvasCtx.stroke();
                    const angleY = Math.atan2(m.corners[1].y - m.corners[0].y, m.corners[1].x - m.corners[0].x);
                    sendAction('twin_rotate', { x: 0, y: -angleY, z: 0 });
                }
            }
            if (currentMode === 'twin') animationFrameId = requestAnimationFrame(processWebcamFrame);
        }

        function init3DMultiView() {
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            renderer.autoClear = false;
            
            // 💡 โค้ชแก้ปัญหาโมเดลจ้าเกินไป: ตั้งค่า Color Encoding ให้รองรับ sRGB สำหรับโมเดล GLTF
            renderer.outputEncoding = THREE.sRGBEncoding;
            
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            for (let i = 0; i < 3; i++) {
                const scene = new THREE.Scene();
                const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
                camera.position.z = 7.5; 
                
                // 💡 โค้ชลดความสว่างแสงลงให้อยู่ในระดับมาตรฐาน โมเดลจะไม่ขาวโพลนอีกต่อไป
                scene.add(new THREE.AmbientLight(0xffffff, 1.0)); 
                const dirLight = new THREE.DirectionalLight(0xffffff, 1.5); 
                dirLight.position.set(5, 5, 5);
                scene.add(dirLight);
                
                scenes.push(scene); cameras.push(camera);
            }
            recreateAllGeometries('torus', '#00ffcc');
            animate();
        }

        function recreateAllGeometries(type, colorHex) {
            for (let i = 0; i < 3; i++) { if (currentMeshes[i]) scenes[i].remove(currentMeshes[i]); }
            currentMeshes = [];

            if (type === 'custom_artifact') {
                const loader = new THREE.GLTFLoader();
                loader.load('Sohn_DoorLock_100463952.glb', function (gltf) {
                    for (let i = 0; i < 3; i++) {
                        const modelClone = gltf.scene.clone();
                        modelClone.rotation.y = viewAngles[i];
                        
                        const box = new THREE.Box3().setFromObject(modelClone);
                        const center = box.getCenter(new THREE.Vector3());
                        const size = box.getSize(new THREE.Vector3());
                        const maxDim = Math.max(size.x, size.y, size.z);
                        
                        const targetSize = 1.6; 
                        const scaleFactor = targetSize / maxDim;
                        
                        modelClone.scale.set(scaleFactor * baseScale, scaleFactor * baseScale, scaleFactor * baseScale);
                        modelClone.position.x = -center.x * scaleFactor * baseScale;
                        modelClone.position.y = -center.y * scaleFactor * baseScale;
                        modelClone.position.z = -center.z * scaleFactor * baseScale;
                        
                        modelClone.userData = { isCustom: true, initialScale: scaleFactor };

                        scenes[i].add(modelClone); currentMeshes.push(modelClone);
                    }
                }, undefined, function (error) {
                    console.error('Three.js Loading Error:', error);
                    alert('โหลดไฟล์ Door Lock ไม่สำเร็จ! กรุณาตรวจสอบว่าชื่อไฟล์ตรงกัน 100% และรันบน Local Server เท่านั้น');
                });
            } else {
                let geometry;
                if (type === 'torus') geometry = new THREE.TorusKnotGeometry(0.8, 0.28, 100, 16);
                else if (type === 'crystal') geometry = new THREE.IcosahedronGeometry(1.1, 0);
                else if (type === 'cone') geometry = new THREE.ConeGeometry(0.9, 1.8, 32);

                const material = new THREE.MeshStandardMaterial({ color: new THREE.Color(colorHex), metalness: 0.3, roughness: 0.3, flatShading: type === 'crystal' });
                for (let i = 0; i < 3; i++) {
                    const mesh = new THREE.Mesh(geometry, material.clone());
                    mesh.rotation.y = viewAngles[i];
                    mesh.scale.set(baseScale, baseScale, baseScale);
                    scenes[i].add(mesh); currentMeshes.push(mesh);
                }
            }
        }
        function createLiveVideoMesh() {
    const videoEl = document.getElementById('remote-video');
    if (!videoEl || !videoEl.srcObject) {
        alert("No camera signal yet. Open camera on mobile first.");
        return;
    }

    for (let i = 0; i < 3; i++) { 
        if (currentMeshes[i]) scenes[i].remove(currentMeshes[i]); 
    }
    currentMeshes = [];

    const videoTexture = new THREE.VideoTexture(videoEl);
    videoTexture.minFilter = THREE.LinearFilter;
    videoTexture.magFilter = THREE.LinearFilter;
    videoTexture.format = THREE.RGBFormat; // ← add this

    // Wait for video dimensions to be available
    const tryCreate = () => {
        const w = videoEl.videoWidth || 640;
        const h = videoEl.videoHeight || 480;
        const aspect = h / w;

        const geometry = new THREE.PlaneGeometry(2, 2 * aspect);
        const material = new THREE.MeshBasicMaterial({ 
            map: videoTexture, 
            side: THREE.DoubleSide 
        });

        for (let i = 0; i < 3; i++) {
            const mesh = new THREE.Mesh(geometry, material.clone());
            mesh.material.map = videoTexture; // share same texture instance
            mesh.rotation.y = viewAngles[i];
            mesh.scale.set(baseScale, baseScale, baseScale);
            mesh.userData = { isCustom: true, initialScale: 1.0, isVideo: true };
            scenes[i].add(mesh);
            currentMeshes.push(mesh);
        }
    };

    if (videoEl.readyState >= 2) tryCreate();
    else videoEl.addEventListener('loadeddata', tryCreate, { once: true });
}
        function animate() {
            requestAnimationFrame(animate); renderer.clear();
            const centerX = window.innerWidth / 2, centerY = window.innerHeight / 2;
            
            const size = Math.min(window.innerWidth, window.innerHeight) * 0.45;
            
            const viewports = [
                { x: centerX - size / 2, y: centerY - size / 2 + baseOffset },
                { x: centerX - size / 2 + (baseOffset * Math.cos((7 * Math.PI) / 6)), y: centerY - size / 2 + (baseOffset * Math.sin((7 * Math.PI) / 6)) },
                { x: centerX - size / 2 + (baseOffset * Math.cos((11 * Math.PI) / 6)), y: centerY - size / 2 + (baseOffset * Math.sin((11 * Math.PI) / 6)) }
            ];
            // inside animate(), before renderer.render(scenes[i], cameras[i])
            if (currentMeshes[0]?.userData?.isVideo) {
                currentMeshes[0].material.map.needsUpdate = true;
            }
            renderer.setScissorTest(true);
            for (let i = 0; i < 3; i++) {
                const vp = viewports[i]; renderer.setScissor(vp.x, vp.y, size, size); renderer.setViewport(vp.x, vp.y, size, size);
                if (currentMode === 'touch' && currentMeshes[i]) currentMeshes[i].rotation.y += 0.003;
                renderer.render(scenes[i], cameras[i]);
            }
        }

        function setupTouchpad() {
            const pad = document.getElementById('area-touch-mode'); if (!pad) return;
            let isDrawing = false, lastX = 0, lastY = 0;
            pad.addEventListener('touchstart', e => { if(currentMode !== 'touch') return; isDrawing = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; });
            pad.addEventListener('touchmove', e => {
                if (!isDrawing || currentMode !== 'touch') return;
                const x = e.touches[0].clientX, y = e.touches[0].clientY;
                sendAction('rotate', { deltaX: x - lastX, deltaY: y - lastY }); lastX = x; lastY = y;
            });
            pad.addEventListener('touchend', () => isDrawing = false);
        }
    </script>
