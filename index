</head>
<body class="bg-black text-white font-sans overflow-hidden m-0 h-screen w-screen selection:bg-transparent">

    <!-- Mode Selection -->
    <div id="mode-selection" class="absolute inset-0 z-50 flex flex-col justify-center items-center bg-white p-6 text-center">
        <div class="mb-4">
            <p class="text-xs text-indigo-950 font-bold tracking-widest uppercase">School of Engineering Physics and Mathematics</p>
            <img src="uea-logo.png" alt="University Logo" class="h-64 w-auto opacity-100 hover:opacity-80 transition-all mx-auto mt-3" onerror="this.style.display='none'">
        </div>
        <h1 class="text-3xl font-black mb-2 text-slate-800"> UEA Hologram Project </h1>
        <div class="flex flex-col gap-4 w-full max-w-xs">
            <button onclick="initPeer('screen')" class="bg-indigo-600 hover:bg-indigo-700 text-white py-4 rounded-2xl font-bold shadow-lg transition-all active:scale-95 text-sm cursor-pointer">
                Display Screen
            </button>
            <div class="relative flex py-2 items-center w-full">
                <div class="flex-grow border-t border-slate-300"></div>
                <span class="flex-shrink mx-4 text-slate-400 text-xs">or</span>
                <div class="flex-grow border-t border-slate-300"></div>
            </div>
            <button onclick="showControllerSetup()" class="bg-slate-800 hover:bg-slate-900 text-white py-4 rounded-2xl font-bold shadow-lg transition-all active:scale-95 text-sm cursor-pointer">
                Guest Access Remote Control
            </button>
            <p class="text-xs text-slate-500 mb-8 max-w-xs"> Sohn Jiraekkaphob </p>
        </div>
    </div>

    <!-- Controller Setup -->
    <div id="controller-setup" class="hidden absolute inset-0 z-50 flex flex-col justify-center items-center bg-white p-6 text-center">
        <div class="w-full max-w-xs text-left mb-6">
            <button onclick="goBackToModeSelection()" class="w-10 h-10 rounded-full bg-slate-100 text-slate-700 flex items-center justify-center hover:bg-slate-200 active:scale-95 transition-all cursor-pointer shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
            </button>
        </div>

        <h2 class="text-xl font-bold mb-2 text-indigo-600">🔗: Connecting to the Guest Controller </h2>
        <p class="text-xs text-slate-500 mb-4">Enter 4 digits number to enter the room display</p>
        <div class="w-full max-w-xs">
            <input id="join-id-input" type="text" pattern="[0-9]*" inputmode="numeric" placeholder="4 Digits Number" class="w-full bg-slate-100 border border-slate-300 rounded-xl py-3 px-4 text-center text-slate-800 font-mono text-lg mb-4 focus:outline-none focus:border-indigo-500">
            <button onclick="connectToScreen()" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-3 rounded-xl font-bold transition-all active:scale-95 text-sm shadow-md cursor-pointer">
                🚀: Connecting Online 
            </button>
        </div>
    </div>

    <!-- Screen View (Display) -->
    <div id="screen-view" class="hidden w-full h-full relative bg-black">
        
        <div id="room-id-box" class="absolute top-4 left-4 z-10 bg-slate-900/90 p-4 rounded-xl border border-slate-700 text-left shadow-lg transition-opacity duration-300">
            <p class="text-[10px] text-slate-400">Online Code Acess:</p>
            <h3 id="display-peer-id" class="text-3xl font-mono font-black text-emerald-400">....</h3>
        </div>
        
        <div id="guide-lines" class="absolute inset-0 pointer-events-none transition-opacity duration-300">
            <div class="absolute inset-0 flex justify-center"><div class="w-[1px] h-full bg-indigo-500/25"></div></div>
            <div class="absolute inset-0 flex items-center"><div class="w-full h-[1px] bg-indigo-500/25"></div></div>
        </div>
        
        <div id="canvas-container" class="w-full h-full"></div>

        <!-- Remote Camera Video Element -->
